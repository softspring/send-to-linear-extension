{
  "manifest_version": 3,
  "name": "Send To Linear",
  "version": "0.1.0",
  "description": "Create Linear issues from selected text in Chrome.",
  "permissions": [
    "contextMenus",
    "identity",
    "notifications",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://api.linear.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icon-128.png"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Send To Linear settings",
    "default_icon": "icon-128.png"
  }
}
